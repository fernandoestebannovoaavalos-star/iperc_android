<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFF8E1"
    android:padding="12dp"
    android:layout_marginTop="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠ Peligro Adicional"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#F57F17"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etTipoAdicional"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tipo de peligro"
        android:inputType="text"
        android:padding="8dp"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etDescripcionAdicional"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Descripción del peligro"
        android:inputType="text"
        android:padding="8dp"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etRiesgoAdicional"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Riesgo / consecuencia"
        android:inputType="text"
        android:padding="8dp"
        android:layout_marginBottom="6dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <EditText
            android:id="@+id/etPAdicional"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="P (1-5)"
            android:inputType="number"
            android:padding="8dp"
            android:layout_marginEnd="4dp"/>

        <EditText
            android:id="@+id/etSAdicional"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="S (1-5)"
            android:inputType="number"
            android:padding="8dp"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <EditText
        android:id="@+id/etMedidasAdicional"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Medidas de control"
        android:inputType="text"
        android:padding="8dp"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btnEliminarAdicional"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="Eliminar"
        android:backgroundTint="#F44336"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:layout_gravity="end"/>

</LinearLayout>