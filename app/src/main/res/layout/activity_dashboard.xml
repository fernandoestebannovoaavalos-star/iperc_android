<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IPERC Digital"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#F97316"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvBienvenido"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="#333333"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvRol"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnNuevoIperc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nuevo Registro IPERC"
        android:backgroundTint="#F97316"
        android:textColor="@android:color/white"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnListaIperc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver Registros IPERC"
        android:backgroundTint="#1E40AF"
        android:textColor="@android:color/white"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSupervisor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Panel Supervisor"
        android:backgroundTint="#1B5E20"
        android:textColor="@android:color/white"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btnCrearUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestión de Usuarios"
        android:backgroundTint="#1F3864"
        android:textColor="#FFFFFF"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btnMiPerfil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👤 Mi Perfil"
        android:backgroundTint="#6B7280"
        android:textColor="#FFFFFF"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerrar Sesión"
        android:backgroundTint="#DC2626"
        android:textColor="@android:color/white"
        android:padding="16dp"/>

</LinearLayout>