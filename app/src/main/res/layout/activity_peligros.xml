<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Peligros Identificados"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#F97316"
        android:padding="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Peligros base -->
            <LinearLayout
                android:id="@+id/contenedorPeligros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- Título peligros adicionales -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠ Peligros Adicionales en Campo"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#F57F17"
                android:layout_marginBottom="8dp"/>

            <!-- Contenedor adicionales -->
            <LinearLayout
                android:id="@+id/contenedorAdicionales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Botón agregar adicional -->
            <Button
                android:id="@+id/btnAgregarAdicional"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="+ Agregar Peligro Adicional"
                android:backgroundTint="#FFF8E1"
                android:textColor="#F57F17"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnFirmar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Firmar Registro"
        android:backgroundTint="#F97316"
        android:textColor="@android:color/white"
        android:padding="16dp"
        android:layout_margin="16dp"/>

</LinearLayout>